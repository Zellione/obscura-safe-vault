# Build outputs
build/
bin/
obj/

# Vendored image-codec staging prefix (built by setup.sh; not committed)
vendor/codecs-prefix/
vendor/codecs-prefix-asan/

# libarchive's own source tree ships a tracked build/ directory (cmake helper
# modules), so its out-of-tree build output goes to a sibling dir instead.
vendor/.libarchive-build/

# premake5 binary (downloaded by setup.sh, not committed)
bin/premake5

# Generated build files
*.make
Makefile
*.ninja
.ninja_deps
.ninja_log

# clangd compilation database (generated by gen.sh; absolute paths, machine-specific)
compile_commands.json

# AI planning artifacts (kept out of the tree — this is a vibe-coded project)
docs/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Compiled objects
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# Test vault files (contain personal data)
*.osv

# Packaging output
dist/

# Local gcov coverage artifacts (CI generates these under build/)
*.gcov
*.gcda
*.gcno
.ninja_lock
*.dmp
