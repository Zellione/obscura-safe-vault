prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libva-drm
Description: obscura-safe-vault VAAPI dlopen shim -- DRM winsys backend (same shim library as libva.pc)
Version: 1.22.0
Requires: libva
Libs: -L${libdir} -losv_vaapi_shim -ldl
Cflags: -I${includedir}
